# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# playwright audit artifacts
.playwright-mcp/
/*.png
/*.jpeg
/*.jpg

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.vercel

# obsidian vault — только UI state, notes коммитим
obsidian/**/.obsidian/workspace*.json
obsidian/**/.obsidian/graph.json
obsidian/**/.obsidian/cache
obsidian/**/.obsidian/appearance.json
obsidian/**/.trash/

# supabase CLI — local project link state (personal, не коммитим)
supabase/.temp/
supabase/.branches/
# Added by code-review-graph
.code-review-graph/
