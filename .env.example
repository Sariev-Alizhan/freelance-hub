# Copy to .env and fill in. Only the NEXT_PUBLIC_ keys ship to the browser.

# --- Instance ---
NEXT_PUBLIC_INSTANCE_HOST=localhost:3000

# --- Supabase (auth + RLS) ---
# Point at hosted Supabase OR your self-hosted Supabase stack.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Postgres (docker compose default — matches the `db` service) ---
DATABASE_URL=postgres://postgres:postgres@db:5432/freelancehub

# --- Object storage (MinIO default — matches the `minio` service) ---
S3_ENDPOINT=http://minio:9000
S3_BUCKET=media
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# --- DID issuer (run `npm run generate-issuer-key` to produce these) ---
ISSUER_ED25519_PRIVATE_KEY=
ISSUER_ED25519_PUBLIC_KEY=

# --- Phase 4 escrow (after you deploy contracts/FreelanceEscrow.sol) ---
NEXT_PUBLIC_ESCROW_CHAIN=8453
NEXT_PUBLIC_ESCROW_CONTRACT=

# --- AI / other ---
ANTHROPIC_API_KEY=

# --- Security / secrets ---
# Required — cron route refuses to run without it
CRON_SECRET=
# Required if you wire up the Telegram bot — webhook refuses without it
# Register via: https://api.telegram.org/bot<TOKEN>/setWebhook?url=...&secret_token=<THIS>
TELEGRAM_WEBHOOK_SECRET=
